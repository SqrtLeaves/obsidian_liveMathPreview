{
	"name": "inline-math-preview",
	"version": "1.0.0",
	"description": "Show a rendered MathJax preview below inline math when the cursor is inside it.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"math",
		"latex"
	],
	"author": "Kimi",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@codemirror/state": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@codemirror/language": "^6.0.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "5.3.3"
	}
}
